# DeepFlow Mobile environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
MIXPANEL_TOKEN=your-mixpanel-token-here
SUPERWALL_API_KEY=pk_your-superwall-key-here
REVENUECAT_API_KEY=your-revenuecat-key-here
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id-here
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id-here
