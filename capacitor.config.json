{
  "appId": "com.deepflow.app",
  "appName": "DeepFlow",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "overlaysWebView": false,
      "style": "DARK",
      "backgroundColor": "#0D0D12"
    },
    "SplashScreen": {
      "backgroundColor": "#0D0D12",
      "showSpinner": false,
      "launchAutoHide": true
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK"
    }
  }
}
