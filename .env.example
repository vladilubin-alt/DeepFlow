# DeepFlow — Root environment (Vite / Web SPA)
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_MIXPANEL_TOKEN=your-mixpanel-token-here
VITE_SUPERWALL_API_KEY=pk_your-superwall-key-here
VITE_REVENUECAT_API_KEY=your-revenuecat-key-here
VITE_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id-here
VITE_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id-here
